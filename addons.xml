<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<addon id="plugin.video.stratos" name="FLIX PRIME PLUS beta" version="1.0.4" provider-name="Stratos/Stock">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>
        <import addon="script.module.beautifulsoup4"/>
        <import addon="script.module.resolveurl"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <assets>
            <icon>http://192.168.1.107/icon.png</icon>
        </assets>
        <summary lang="fr">Extension Vidéo FLIX PRIME PLUS beta</summary>
        <description lang="fr">Le plugin Stratos pour regarder vos contenus sur Flemmix.</description>
    </extension>
</addon>

<addon id="repository.stratos" name="Stratos Repository" version="1.0.4" provider-name="Stratos">
    <extension point="xbmc.addon.repository" name="Stratos Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/equationstratos/flixprimeplus/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/equationstratos/flixprimeplus/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/equationstratos/flixprimeplus/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Dépôt Officiel Stratos</summary>
        <platform>all</platform>
        <assets>
            <icon>https://raw.githubusercontent.com/equationstratos/flixprimeplus/main/repository.stratos/icon.png</icon>
            <fanart>https://raw.githubusercontent.com/equationstratos/flixprimeplus/main/repository.stratos/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

</addons>
